# Пример переменных окружения

# База данных (SQLite по умолчанию)
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_strong_random_secret"

# GitHub OAuth (создайте приложение на https://github.com/settings/developers)
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Google OAuth (создайте приложение на https://console.cloud.google.com/apis/credentials)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Yandex OAuth (создайте приложение на https://oauth.yandex.ru/)
AUTH_YANDEX_ID=""
AUTH_YANDEX_SECRET=""

